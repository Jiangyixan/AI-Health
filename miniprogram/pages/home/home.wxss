page {
  background-color: #f8f8f8;
}

.container {
  height: 900rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.image-default-avatar {
  width: 150rpx;
  margin-bottom: 16rpx;
}

.button-login {
  width: 90%;
  border-radius: 100px;
  margin: 15px 0;
  background-color: rgb(88, 56, 144);
  color: #f8f8f8;
}

.button-register {
  width: 90%;
  border-radius: 100px;
  margin: 15px 0;
  background-color: rgb(88, 56, 144);
  color: #f8f8f8;
}

/* 按钮下方提示消息的样式 */
.tips-text {
  font-size: 12px;
  color: gray;
}

/* 用户信息样式 */
.top-box {
  height: 400rpx;
  background-color: rgb(88, 56, 144);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 10px;
  margin-left: 20px;
  margin-right: 20px;
}

/* 用户头像样式 */
.top-box .avatar {
  display: block;
  width: 120px;
  height: 120px;
  border-radius: 60px;
  border: 2px solid white;
  box-shadow: 0 1px 5px black;
}

/* 用户用户名样式 */
.top-box .username {
  color: white;
  font-weight: bold;
  font-size: 16px;
  margin-top: 10px;
}

/* 面板样式设置 */
.panel {
  background-color: white;
  border-radius: 3px;
  margin-top: 20px;
  margin-left: 20px;
  margin-right: 20px;
}

.panel-list-item {
  height: 45px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 15px;
  padding: 0 10px;
}


/* 箭头样式 */
.panel-list-item image {
  width: 30rpx;
  height: 30rpx;
}
