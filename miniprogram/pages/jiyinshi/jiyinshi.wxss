.container {
    padding: 0;
    background-color: #f8f8f8;
    min-height: 100vh;
    padding-top: 180rpx;
    /* 为固定的标题和导航栏留出空间 */
}

.header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    padding: 20rpx 0;
    text-align: center;
    background-color: #fff;
    z-index: 100;
    border-bottom: 1rpx solid #eee;
}

.title {
    font-size: 36rpx;
    font-weight: bold;
    color: #333;
}

/* 三餐导航 */
.meal-nav {
    position: fixed;
    top: 90rpx;
    /* 标题栏下方 */
    left: 0;
    right: 0;
    display: flex;
    justify-content: space-between;
    /* 改为space-between让按钮更好地平铺 */
    padding: 0;
    background-color: #fff;
    z-index: 99;
    box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
    border-bottom: 1rpx solid #eee;
}

.meal-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 33.33%;
    /* 确保每个按钮占据三分之一的宽度 */
    padding: 20rpx 0;
    box-sizing: border-box;
}

.meal-icon {
    width: 80rpx;
    height: 80rpx;
    margin-bottom: 10rpx;
    display: flex;
    justify-content: center;
    align-items: center;
}

.meal-icon image {
    width: 70rpx;
    height: 70rpx;
}

.meal-name {
    font-size: 28rpx;
    color: #333;
}

/* 打卡历史部分调整，确保在固定导航栏下方显示 */
.history-section {
    margin-top: 80rpx;
    background-color: #fff;
    border-radius: 12rpx;
    padding: 30rpx;
    box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
    margin-left: 20rpx;
    margin-right: 20rpx;
}

/* 其他样式保持不变 */
.section-title {
    font-size: 32rpx;
    font-weight: bold;
    margin-bottom: 20rpx;
    color: #333;
}

.history-list {
    max-height: 600rpx;
    overflow-y: auto;
}

.history-item {
    padding: 20rpx 0;
    border-bottom: 1rpx solid #eee;
}

.history-item:last-child {
    border-bottom: none;
}

.empty-history {
    padding: 40rpx 0;
    text-align: center;
    color: #999;
    font-size: 28rpx;
}