/* 设置部分标题的样式 */
.section-title {
  font-size: 18px;
  font-weight: bold;
  margin-bottom: 10px;
}

/* 设置部分内容的样式 */
.section-content {
  font-size: 16px;
  line-height: 1.5;
}

/* 设置文本样式 */
.text {
  font-size: 16px;
  line-height: 1.5;
}
