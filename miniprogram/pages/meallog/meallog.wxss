/* 页面容器 */
.meal-log-container {
    display: flex;
    flex-direction: column;
    width: 100%;
    height: 100vh;
    background-color: #f5f5f5;
}

/* 顶部导航栏 */
.nav-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20rpx 30rpx;
    background-color: #ffffff;
    border-bottom: 1rpx solid #e0e0e0;
    position: relative;
    height: 80rpx;
}

.back-btn {
    font-size: 40rpx;
    color: #333;
    width: 60rpx;
    display: flex;
    align-items: center;
}

.page-title {
    position: absolute;
    left: 0;
    right: 0;
    text-align: center;
    font-size: 34rpx;
    font-weight: 500;
    color: #333;
    pointer-events: none;
}

.publish-btn {
    background-color: #f2f2f2;
    color: #07c160;
    padding: 10rpx 30rpx;
    border-radius: 30rpx;
    font-size: 30rpx;
}

/* 内容区域 */
.content-area {
    flex: 1;
    padding: 30rpx;
}

/* 文本输入框 */
.text-input-area {
    position: relative;
    margin-bottom: 30rpx;
}

.content-input {
    width: 100%;
    height: 240rpx;
    padding: 20rpx;
    box-sizing: border-box;
    background: #fff;
    border-radius: 10rpx;
    font-size: 30rpx;
}

.word-count {
    position: absolute;
    right: 20rpx;
    bottom: 10rpx;
    font-size: 24rpx;
    color: #888;
}

/* 图片上传区域 */
.image-upload-area {
    display: flex;
    flex-wrap: wrap;
    margin: 0 -10rpx;
}

.uploaded-images {
    display: flex;
    flex-wrap: wrap;
}

.image-item {
    position: relative;
    width: 210rpx;
    height: 210rpx;
    margin: 10rpx;
    background-color: #e0e0e0;
    overflow: hidden;
}

.image-item image {
    width: 100%;
    height: 100%;
}

.delete-btn {
    position: absolute;
    top: 0;
    right: 0;
    width: 40rpx;
    height: 40rpx;
    background-color: rgba(0, 0, 0, 0.4);
    border-radius: 50%;
    display: flex;
    justify-content: center;
    align-items: center;
    color: #fff;
    font-size: 30rpx;
}

.upload-btn-container {
    width: 210rpx;
    height: 210rpx;
    margin: 10rpx;
}

.upload-btn {
    width: 100%;
    height: 100%;
    background-color: #ffffff;
    display: flex;
    justify-content: center;
    align-items: center;
    border: 1px dashed #ccc;
}

.upload-icon {
    font-size: 80rpx;
    color: #999;
    line-height: 80rpx;
}

/* 食物标签区域 */
.food-tags-area {
    margin-top: 40rpx;
}

.tags-title {
    font-size: 28rpx;
    color: #666;
    margin-bottom: 20rpx;
}

.tags-container {
    display: flex;
    flex-wrap: wrap;
    margin: 0 -10rpx;
}

.tag-item {
    padding: 10rpx 25rpx;
    background-color: #f2f2f2;
    border-radius: 30rpx;
    margin: 10rpx;
    font-size: 26rpx;
    color: #333;
}

.tag-item.selected {
    background-color: #e6f7e1;
    color: #07c160;
    border: 1rpx solid #07c160;
}

.add-tag-btn {
    padding: 10rpx 25rpx;
    background-color: #fff;
    border: 1rpx dashed #ccc;
    border-radius: 30rpx;
    margin: 10rpx;
    font-size: 26rpx;
    color: #666;
}