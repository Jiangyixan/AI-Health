.dialogue{
  background-color: rgb(248, 248, 248);
  position: fixed; /* 使用 fixed 定位 */
  top: 0;
  left: 0;
  width: 100%; /* 宽度填满整个页面 */
  height: 100%; /* 高度填满整个页面 */
}
.dialogue-block{
  margin-left: 25rpx;
  margin-right: 25rpx;
  margin-top: 20rpx;
  width: 685rpx;
  height: 100rpx;
  background-color: rgb(255, 255, 255);
  border-radius: 10rpx;
  padding: 10rpx; /* 调整内部内容的位置 */
}

.dialogue-content{
  font-weight: normal;
  margin-left: 10rpx;
}

.dialogue-time{
  font-size: 25rpx;
  font-weight: 400;
  font-family: initial;
  text-align: right;
  margin-right: 10rpx;
  margin-top: 20rpx;
}